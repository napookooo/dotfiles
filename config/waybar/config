{
    "layer": "top", // Waybar at top layer
    "position": "top", // Waybar position (top|bottom|left|right)
    "height": 37, // Waybar height (to be removed for auto height)
    "width": "auto", // Waybar width
    "spacing": 3, // Gaps between modules (3px)
    // Choose the order of the modules
    "modules-left": ["custom/distro","hyprland/workspaces","custom/music","tray","custom/notification"],
    "modules-center":["clock"],
    "modules-right": ["idle_inhibitor", "pulseaudio", "network", "cpu", "memory", "temperature", "backlight", "custom/swaylock", "battery"],
    // Modules configuration
     "hyprland/workspaces": {
         "disable-scroll": true,
         "all-outputs": true,
         "warp-on-scroll": false,
         "format": "{icon}",
         "format-icons": {
           "1": "дёҖ",
           "2": "дәҢ",
           "3": "дёү",
           "4": "еӣӣ",
           "5": "дә”",
           "6": "е…ӯ",
           "7": "дёғ",
           "8": "е…«",
           "9": "д№қ",
           "10": "еҚҒ",
         },
         "persistent-workspaces": {
          },
     },
     "custom/distro": {
        "format":" у°ЈҮ  ",
        "on-click": "/home/cuzof/ricing/wallpaper/random"
     },
     "custom/swaylock": {
        "format": " оҷІ ",
        "on-click": "swaylock -f --clock --effect-blur 10x2 -i /home/cuzof/ricing/wallpaper/flatppuccin_4k_macchiato_inverted.png",
        "tooltip": false,
      },
      "idle_inhibitor": {
        "format": "{icon} ",
        "format-icons": {
            "activated": " пҒ® ",
            "deactivated": " пҒ° "
        }
    },
    "tray": {
        // "icon-size": 21,
        "spacing": 10
    },
    "clock": {
        // "timezone": "America/New_York",
        "interval": 1,
        "format": "{:%H:%M:%S}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format-alt": "{:%Y-%m-%d}"
    },
    "cpu": {
        "format": "{usage}% п’ј ",
        "tooltip": false
    },
    "memory": {
        "format": "{}% пғү "
    },
    "temperature": {
        // "thermal-zone": 2,
        // "hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
        "critical-threshold": 80,
        // "format-critical": "{temperatureC}В°C {icon}",
        "format": "{temperatureC}В°C {icon}",
        "format-icons": ["пӢӢ", "пӢү", "пӢҮ"],
        "tooltip": "false"
    },
    "backlight": {
        // "device": "acpi_video1",
        "format": "{percent}% {icon}",
        "format-icons": ["оҺҚ", "оҸ“", "оҸ‘", "оҸҸ", "оҸҺ", "оҸҚ", "оҸҠ", "оҸҲ", "оҺӣ"]
    },
    "battery": {
        "states": {
            // "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{capacity}% {icon}",
        "format-charging": "{capacity}% у°Ӯ„",
        "format-plugged": "{capacity}% пҮҰ ",
        "format-alt": "{time} {icon} ",
        // "format-good": "", // An empty format will hide the module
        // "format-full": "",
        "format-icons": ["пү„", "пүғ", "пүӮ", "пүҒ", "пүҖ"]
    },
    "network": {
        // "interface": "wlp2*", // (Optional) To force the use of this interface
        "format-wifi": "{essid} ({signalStrength}%) пҮ« ",
        "format-ethernet": "{ipaddr}/{cidr} пһ– ",
        "tooltip-format": "{ifname} via {gwaddr} пһ– ",
        "format-linked": "{ifname} (No IP) пһ– ",
        "format-disconnected": "Disconnected вҡ  ",
        "format-alt": "{ifname}: {ipaddr}/{cidr}"
    },
    "pulseaudio": {
        // "scroll-step": 1, // %, can be a float
        // "format": "{volume}% {icon} {format_source}",
        "format": "{volume}% {icon} ",
        "format-bluetooth": "{volume}% {icon} пҠ” ",
        "format-bluetooth-muted": "п‘Ұ {icon} пҠ” ",
        "format-muted": "п‘Ұ {format_source}",
        "format-source": "{volume}% п„° ",
        "format-source-muted": "п„ұ ",
        "format-icons": {
            "headphone": "пҖҘ",
            "hands-free": "пҖҘ",
            "headset": "пҖҘ",
            "phone": "пӮ•",
            "portable": "пӮ•",
            "car": "пҶ№",
            "default": ["пҖҰ", "пҖ§", "пҖЁ"]
        },
        "on-click": "pavucontrol"
    },
    "custom/notification": {
        "tooltip": false,
        "format": "{icon} {} ",
        "format-icons": {
            "notification": "пғі<span foreground='red'><sup>п‘„</sup></span>",
            "none": "пғі",
            "dnd-notification": "пҮ¶<span foreground='red'><sup>п‘„</sup></span>",
            "dnd-none": "пҮ¶",
            "inhibited-notification": "пғі<span foreground='red'><sup>п‘„</sup></span>",
            "inhibited-none": "пғі",
            "dnd-inhibited-notification": "пҮ¶<span foreground='red'><sup>п‘„</sup></span>",
            "dnd-inhibited-none": "пҮ¶"
        },
        "return-type": "json",
        "exec-if": "which swaync-client",
        "exec": "swaync-client -swb",
        "on-click": "swaync-client -t -sw",
        "escape": true
    },
    "custom/music": {
      "format": "{icon}{}",
      "format-icons": {
          // "Playing": "п…„ ", // Uncomment if not using caway
          "Paused": "вҸёпёҺ ",
          "Stopped": "&#x202d;пӯҘ " // This stop symbol is RTL. So &#x202d; is left-to-right override.
      },
      "escape": true,
      "tooltip": true,
      "exec": "/home/cuzof/ricing/script/caway -b 14 -f 30",
      "return-type": "json",
      "on-click": "playerctl play-pause",
      "on-scroll-up": "playerctl previous",
      "on-scroll-down": "playerctl next",
      "on-click-right": "g4music",
      "max-length": 33
  }
}
